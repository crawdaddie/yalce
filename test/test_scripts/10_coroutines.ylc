let test = module () ->

let test_iter_all_void = 
  let co_void = (fn () ->
    yield 1;
    yield 2;
    yield 3;
  ) in
  let co = co_void ()
  in
     co () == Some 1
  && co () == Some 2
  && co () == Some 3
  && co () == None
  && co () == None
;


let test_embed_seq = fn () ->

  let ne = fn () ->
    yield 300;
    yield 400
  ;;

  let co_void = fn () ->
    yield 1;
    yield 2;
    yield ne ();
    yield 3
  ;;

  let co = co_void ();
     co () == Some 1
  && co () == Some 2
  && co () == Some 300
  && co () == Some 400
  && co () == Some 3
;;
let test_rec = fn () ->
  let co_void_rec = fn () ->
    yield 1;
    yield 2;
    yield (co_void_rec ())
  ;;


  let co = co_void_rec ();

     co () == Some 1
  && co () == Some 2
  && co () == Some 1
;;

let test_fib_cor = fn () ->

  let fib = fn a b ->
    yield a;
    yield fib b (a + b)
  ;;

  let co = fib 0 1 in
     co () == Some 0
  && co () == Some 1
  && co () == Some 1
  && co () == Some 2
  && co () == Some 3
  && co () == Some 5
  && co () == Some 8
  && co () == Some 13
  && co () == Some 21
  && co () == Some 34
;;

let test_geo = fn () ->
  let geo = fn a ->
    yield a;
    yield geo (a * 2.0)
  ;;

  let co = geo 1. in
     co () == Some 1.
  && co () == Some 2.
  && co () == Some 4.
  && co () == Some 8.
  && co () == Some 16.
;;
let test_iter_all_arg = fn () ->

  let co_void_arg = fn a ->
    yield 1;
    yield a;
    yield 3
  ;;

  let co = co_void_arg 2 in
     (co () == Some 1)
  && (co () == Some 2)
  && (co () == Some 3)
  && (co () == None)
;;

let test_iter_boundary_xers = fn () ->

  let co_void_arg = fn () ->
    yield 1;
    let x = 200; 
    yield 2;
    yield x;
    yield 3
  ;;

  let co = co_void_arg () in
     (co () == Some 1)
  && (co () == Some 2)
  && (co () == Some 200)
  && (co () == Some 3)
  && (co () == None)
;;

let test_nested_coroutines = fn () ->
  let cor1 = fn () ->
    yield 1
  ;;

  let cor2 = fn () ->
    yield cor1 ();
    yield 2
  ;;

  let cor3 = fn () ->
    yield cor2 ();
    yield 3
  ;;

  let cor = fn () ->
    yield cor3 ();
    yield 4 
  ;;

  let x = cor () in

     x () == Some 1 
  && x () == Some 2 
  && x () == Some 3 
  && x () == Some 4
  && x () == None
;;


let test_iter_array = fn () ->
  let x = iter_of_array [|1,2,3,4|] in

     x () == Some 1 
  && x () == Some 2 
  && x () == Some 3 
  && x () == Some 4
  && x () == None
  
;;
#
let test_iter_list = fn () ->
  let x = iter_of_list [1,2,3,4] in

     x () == Some 1 
  && x () == Some 2 
  && x () == Some 3 
  && x () == Some 4
  && x () == None
;;
#
let test_cor_loop = fn () ->
  let c = fn () -> yield 1; yield 2; yield 3;;
  let x = c () |> cor_loop in 
     x () == Some 1 
  && x () == Some 2 
  && x () == Some 3 
  && x () == Some 1 
  && x () == Some 2 
  && x () == Some 3 
  && x () == Some 1
;;

let test_cor_map = fn () ->
  let c = fn () -> yield 1; yield 2; yield 3;;
  let x = c () |> cor_map ((*) 2.) in 
     x () == Some 2. 
  && x () == Some 4. 
  && x () == Some 6. 
  && x () == None

;;
#
let test_cor_loop_and_map = fn () ->
  let c = fn () -> yield 1; yield 2; yield 3;;
  let x = c () |> cor_loop |> cor_map ((*) 2) in 
  let y = c () |> cor_map ((*) 2) |> cor_loop in 


     (let xx = x () in let yy = y () in xx == yy && xx == Some 2) 
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 4)
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 6)
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 2)
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 4)
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 6)
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 2)
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 4)
  && (let xx = x () in let yy = y () in xx == yy && xx == Some 6)

;;
let test_cor_stop = fn () ->
  let c = fn () -> yield 1; yield 2; yield 3;;
  let x = c () in
  (x () == Some 1) && (cor_stop x; x () == None)
;;

let test_loop_iter_list = fn () ->
 let x = [ 1,2,3 ] |> iter_of_list |> cor_loop;

     x () == Some 1
  && x () == Some 2
  && x () == Some 3
  && x () == Some 1
  && x () == Some 2
  && x () == Some 3
;;

let test_loop_iter_array = fn () ->
 let x = [| 1,2,3 |] |> iter_of_array |> cor_loop;

     x () == Some 1
  && x () == Some 2
  && x () == Some 3
  && x () == Some 1
  && x () == Some 2
  && x () == Some 3

;;

let test_zip = fn () ->
  let a = fn () ->
    yield 1;
    yield 2;
    yield 3
  ;;


  let b = fn () ->
    yield 1.;
    yield 2.;
    yield 3.;
    yield 3.
  ;;
  let c = cor_zip (a ()) (b ());
  let x = c ();

  match x with
    | Some (1, 1.) -> true
    | _ -> false

;;
