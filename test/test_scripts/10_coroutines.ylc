let test_iter_array = fn () ->
  let x = iter_of_array [|1,2,3,4|] in

     x () == Some 1 
  && x () == Some 2 
  && x () == Some 3 
  && x () == Some 4
  && x () == None
  
;;

let test_iter_list = fn () ->
  let x = iter_of_list [1,2,3,4] in

     x () == Some 1 
  && x () == Some 2 
  && x () == Some 3 
  && x () == Some 4
  && x () == None
;;

