let test_cor_map = fn () ->
  let c = fn () -> yield 1; yield 2; yield 3;;
  let x = c () |> cor_map ((*) 2.) in 
     x () == Some 2. 
  && x () == Some 4. 
  && x () == Some 6. 
  && x () == None

;;

