import std/Arrays;

let test = module () ->
  let test_sum_doubles = fn () ->
    let sum = Arrays.fold (+) 0. [|1., 2., 3.|];
    sum == 6.
    ;;

  let test_sum_ints = fn () ->
    let sum = Arrays.fold (+) 0 [|1, 2, 3|];
    sum == 6
    ;;

  let test_foldi = fn () -> 
    let sum = Arrays.foldi (fn i r x -> r + i) 0 [|1,2,3|];
    sum == 3
    ;;

;
