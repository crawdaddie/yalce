open DSP;
compile_audio_fn ( 
  let fdn = fn d1 d2 d3 d4 inp -> 
    let dts = [|d1, d2, d3, d4|];
    let dls = [|
      delay_line 2,
      delay_line 2,
      delay_line 2,
      delay_line 2,
    |];

    let counter = [| 0 |];
    let w = counter[0];
    counter[0] := (w + 1) % (array_size (dll[0]));
    inp 
);


compile_audio_fn ( 
  let imp = fn () -> 
    trig 1
    |> decay 0.1
    |> (*) (sin_osc 400)
    |> fdn 0.2 0.3 0.5 0.7
);



imp () |> play_node


