open DSP;
import std/Math;

compile_audio_fn ( 
  let grain_reverb = fn d1 d2 d3 d4 rt60 inp -> 
    let M = [|
      -0.5,  0.5,  0.5,  0.5,
       0.5, -0.5,  0.5,  0.5,
       0.5,  0.5, -0.5,  0.5,
       0.5,  0.5,  0.5, -0.5
    |];
    let b = array_fill_const 4 1.;
    let c = array_fill_const 4 0.25;


    let dls = [|
      (delay_line 1, d1),
      (delay_line 1, d2),
      (delay_line 1, d3),
      (delay_line 1, d4),
    |];

    let dl0, _ = dls[0];
    let max_size = array_size dl0;

    let counter = [| 0 |];
    let w = counter[0];

    let t = trig 10;
    let y = dsp_array.map (fn (dl, dt) -> 

      let pos = (w - sample_rate * dt) / sample_rate;
      # tabread_samp dl (w - sample_rate * dt)
      t |> grains 30 dl
        (arr_choose [| 1., 2.|] t)
        (pos - lfnoise0 20 0 0.2)
        # pos
        0.15;
    ) dls;


    array_fill_const 4 0.
    |> dsp_mmul_op M y
    |> dsp_array.mapi (fn i d -> 
      let (dl, dt) = dls[i];
      dl[w] := inp * b[i] + (
        d
        |> (*) (Math.pow 10.0 ((-3.0 * dt) / rt60)) # per-delay-line gamma output gain
        |> Filter.lpf1p 8000
        |> Filter.hpf1p 200
      )
    )
    ;

    counter[0] := (w + 1) % max_size;
    inp + (vec_dot c y)
);

