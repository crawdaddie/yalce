open DSP;

import std/Math;


compile_audio_fn ( 
  let imp = fn () -> 
    trig 1.
    |> adsr 0.001 0.01 0.5 0.2
    # |> decay 0.5
    |> (*) (sin_osc 600)
    |> Reverb.fdn8 0.0199  0.0260  0.0341  0.0440  0.0581  0.0759  0.0990  0.1291 10
    # |> Reverb.fdn4 0.0581  0.0759  0.0990  0.1291 10

);



imp () |> play_node


