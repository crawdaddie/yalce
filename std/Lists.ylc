let test = module () ->
  let test_sum_doubles = fold (+) 0. [1., 2., 3.] == 6.;
  let test_sum_ints = fold (+) 0 [1, 2, 3] == 6;
  let test_last = last [1, 2, 3 ] == 3;
  let test_map_plus = map ((+) 1) [0,1,2,3] == [1,2,3,4];
  let test_map_to_double = map (fn x -> Double x) [0,1,2,3] == [0.,1.,2.,3.];
