let test = module () ->
  let test_sum_doubles = fold (+) 0. [1., 2., 3.] == 6.;
  let test_last = last [1, 2, 3 ] == 3;
  let test_map_plus = map ((+) 1) [0,1,2,3] == [1,2,3,4];
  let test_filter = ([1,2,3,7,8,9] |> filter (fn x -> x < 5)) == [1,2,3];
  let _ = print `sum ints: {fold (+) 0 [1, 2, 3]}\n`;
  let test_sum_ints = fold (+) 0 [1, 2, 3] == 6;
  let _ = print `map to double: {map (fn x -> Double x) [0,1,2,3]}\n`;
  let test_map_to_double = map (fn x -> Double x) [0,1,2,3] == [0.,1.,2.,3.];
  let test_foldi = foldi (fn i s x -> i + s + x) 0 [0,0,0] == 3
;
