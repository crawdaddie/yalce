let print_list = fn a: (List of T) ->
  print "["; 
  for l = iter_of_list a in (
    print `{l}, `
  );
  print "]\n" 
;;

let fold = fn f: (R -> T -> R) res: (R) a: (List of T) ->
  match a with
  | [] -> res
  | x::rest -> fold f (f res x) rest
;;

# let foldi = fn f: (Int -> R -> T -> R) res: (R) a: (List of T) ->
#   fold (fn (i, r) x -> (i+1, f i r x)) (0, res) a
# ;;

let last = fn l ->
  match l with
  | x::[] -> x
  | _::rest -> last rest
;;

let head = fn l ->
  match l with
  | x::rest -> x
  | x::[] -> x 
;;


let rev = fn l ->
  let aux = fn l res ->
    match l with
    | [] -> res
    | x :: rest -> aux rest (x :: res)
  ;;
  aux l []
;;

let map = fn f l ->
  let aux = fn f l res -> 
    match l with
    | [] -> res
    | x :: rest -> aux f rest (f x :: res) 
  ;;
  aux f l [] |> rev
;;

