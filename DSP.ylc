#     #
#     # The example is more or less a Schroeder reverb - a signal passed through a parallel bank of comb filters which then pass through a series of allpass filters.
#     # ```supercollider
#     # (
#     # {
#     # var s, z, y;
#     #     // 10 voices of a random sine percussion sound :
