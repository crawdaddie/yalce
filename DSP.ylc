# builtin type declarations
# extern fn symbols are later overridden by the constructor method of libaudio_jit.so
let sq_osc = extern fn Double -> Double;
let saw_osc = extern fn Double -> Double;
let sin_osc = extern fn Double -> Double;
let phasor = extern fn Double -> Double;
let trig = extern fn Double -> Double;
let linscale = extern fn Double -> Double -> Double -> Double -> Double;
let bipolar_scale = extern fn Double -> Double -> Double -> Double;
let unipolar_scale = extern fn Double -> Double -> Double -> Double;
let wrap = extern fn Double -> Double -> Double -> Double;
let clampup = extern fn Double -> Double -> Double;
let fold = extern fn Double -> Double -> Double -> Double;
let delay = extern fn Double -> Double -> Double -> Double -> Double;
let delay1 = extern fn Double -> Double -> Double -> Double -> Double; # delay with linearly interpolated reads
let allpass = extern fn Double -> Double -> Double -> Double -> Double;
let allpass1 = extern fn Double -> Double -> Double -> Double -> Double; # linearly interpolating
let alloc_delay = extern fn Double -> Array of Double;
let tabread = extern fn Array of Double -> Double -> Double;
let tabread1 = extern fn Array of Double -> Double -> Double;
let tabwrite = extern fn Array of Double -> Double -> Double -> Double;
let fdn4 = extern fn Double -> Double -> Double -> Double -> Double -> Double -> Double -> Double; # d1 d2 d3 d4 max_delay fb input
let fdn4m = extern fn Array of Double -> Double -> Double -> Double -> Double -> Double -> Double -> Double -> Double; # matrix16 d1 d2 d3 d4 max_delay fb input
let white = extern fn () -> Double;
let bufref = extern fn Ptr -> Ptr;
let bufread = extern fn Double -> Ptr -> Double;
let lfnoise0 = extern fn Double -> Double -> Double -> Double;
let lfnoise1 = extern fn Double -> Double -> Double -> Double;
let trig_choose = extern fn Array of T -> Double -> T ;
let spf = extern fn () -> Double;
let sah = extern fn () -> Double -> Double -> Double;
#                       buf    rate      start_pos trig
let bufplay = extern fn Ptr -> Double -> Double -> Double -> Double;
#                      max_grains   buf    rate      pos       width     trig
let grains = extern fn Int ->       Ptr -> Double -> Double -> Double -> Double;
let adsr = extern fn Double -> Double -> Double -> Double -> Double -> Double;
let kill_on_end = extern fn Double -> Double;

let dsp_mmul_op = extern fn Array of Double -> Array of Double -> Array of Double -> ();
let dsp_array_sum = extern fn Array of Double -> Double;

# let compile_audio_fn = extern fn T -> (Array of Double -> Ptr);
# type CompiledSynth = (Array of Double -> Synth, Int);

let compile_audio_fn = extern fn T -> (
  cons: (Array of Double -> Synth),
  get_idx: (String -> Int),
  set_scalar: (String -> Uint64 -> Double -> Synth -> Synth),
  set_trig: (String -> Uint64 -> Synth -> Synth),
);

let register_audio_op = extern fn T -> Int;
let get_input_node = extern fn Synth -> Int -> Synth;
let set_const_inlet = extern fn Synth -> Double -> ();
let _ = dlopen "libs/audio_jit/libaudio_jit.so";
# Array of Double -> Synth;

