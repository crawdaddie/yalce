compile_audio_fn (
  let fdn8 = fn d1 d2 d3 d4 d5 d6 d7 d8 rt60 inp ->

    # 8x8 generalised conference matrix: M = (2/8)*J - I
    # diagonal = -3/4, off-diagonal = 1/4 — orthogonal, lossless
    let M = [|
      -0.75,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25,
       0.25, -0.75,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25,
       0.25,  0.25, -0.75,  0.25,  0.25,  0.25,  0.25,  0.25,
       0.25,  0.25,  0.25, -0.75,  0.25,  0.25,  0.25,  0.25,
       0.25,  0.25,  0.25,  0.25, -0.75,  0.25,  0.25,  0.25,
       0.25,  0.25,  0.25,  0.25,  0.25, -0.75,  0.25,  0.25,
       0.25,  0.25,  0.25,  0.25,  0.25,  0.25, -0.75,  0.25,
       0.25,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25, -0.75,
    |];
    let b = array_fill_const 8 1.;
    let c = array_fill_const 8 0.125;

    let dls = [|
      (delay_line 1, d1),
      (delay_line 1, d2),
      (delay_line 1, d3),
      (delay_line 1, d4),
      (delay_line 1, d5),
      (delay_line 1, d6),
      (delay_line 1, d7),
      (delay_line 1, d8),
    |];

    let dl0, _ = dls[0];
    let max_size = array_size dl0;

    let counter = [| 0 |];
    let w = counter[0];

    let y = dsp_array.map (fn (dl, dt) ->
      tabread_samp dl (w - sample_rate * dt)
    ) dls;

    array_fill_const 8 0.
    |> dsp_mmul_op M y
    |> dsp_array.mapi (fn i d ->
      let (dl, dt) = dls[i];
      dl[w] := inp * b[i] + (
        d
        |> (*) (Math.pow 10.0 ((-3.0 * dt) / rt60))
        |> Filter.lpf1p 8000
        |> Filter.hpf1p 200
      )
    )
    ;

    counter[0] := (w + 1) % max_size;
    inp + (vec_dot c y)
);

compile_audio_fn (
  let fdn8rs = fn rs rt60 inp ->

    # 8x8 generalised conference matrix: M = (2/8)*J - I
    # diagonal = -3/4, off-diagonal = 1/4 — orthogonal, lossless
    let M = [|
      -0.75,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25,
       0.25, -0.75,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25,
       0.25,  0.25, -0.75,  0.25,  0.25,  0.25,  0.25,  0.25,
       0.25,  0.25,  0.25, -0.75,  0.25,  0.25,  0.25,  0.25,
       0.25,  0.25,  0.25,  0.25, -0.75,  0.25,  0.25,  0.25,
       0.25,  0.25,  0.25,  0.25,  0.25, -0.75,  0.25,  0.25,
       0.25,  0.25,  0.25,  0.25,  0.25,  0.25, -0.75,  0.25,
       0.25,  0.25,  0.25,  0.25,  0.25,  0.25,  0.25, -0.75,
    |];
    let b = array_fill_const 8 1.;
    let c = array_fill_const 8 0.125;

    # let 0.0199  0.0260  0.0341  0.0440  0.0581  0.0759  0.0990  0.1291

    let dls = [|
      (delay_line 1, 0.0199),
      (delay_line 1, 0.0260),
      (delay_line 1, 0.0341),
      (delay_line 1, 0.0440),
      (delay_line 1, 0.0581),
      (delay_line 1, 0.0759),
      (delay_line 1, 0.0990),
      (delay_line 1, 0.1291),
    |];

    let dl0, _ = dls[0];
    let max_size = array_size dl0;

    let counter = [| 0 |];
    let w = counter[0];

    let y = dsp_array.map (fn (dl, dt) ->
      tabread_samp dl (w - sample_rate * dt * rs )
    ) dls;

    array_fill_const 8 0.
    |> dsp_mmul_op M y
    |> dsp_array.mapi (fn i d ->
      let (dl, dt) = dls[i];
      dl[w] := inp * b[i] + (
        d
        |> (*) (Math.pow 10.0 ((-3.0 * dt * rs) / rt60))
        |> Filter.lpf1p 8000
        |> Filter.hpf1p 200
      )
    )
    ;

    counter[0] := (w + 1) % max_size;
    inp + (vec_dot c y)
);

# fdn8 presets — 8 log-spaced near-prime delays (samples at 48kHz):
#   room:       719  907 1153 1471 1861 2357 2999 3803   sum=15270
#   concert:  ×2.65  1907 2399 3061 3907 4931 6247 7949 10079
#   cathedral: ×6.28  4517 5701 7243 9239 11689 14797 18839 23879

compile_audio_fn (
  let room = fn inp ->
    # Studio room (~0.5s rt60) — delays 15–79ms
    fdn8 0.0150 0.0189 0.0240 0.0307 0.0388 0.0491 0.0625 0.0792 0.5 inp
);

compile_audio_fn (
  let concert = fn inp ->
    # Concert hall (~2.0s rt60) — delays 40–210ms
    fdn8 0.0397 0.0500 0.0638 0.0814 0.1027 0.1301 0.1656 0.2100 2.0 inp
);

compile_audio_fn (
  let cathedral = fn inp ->
    # Cathedral (~5.0s rt60) — delays 94–497ms
    fdn8 0.0941 0.1188 0.1509 0.1925 0.2435 0.3083 0.3925 0.4975 5.0 inp
);

compile_audio_fn (
  let mega_cathedral = fn inp ->
    # Cathedral (~5.0s rt60) — delays 94–497ms
    fdn8 0.0941 0.1188 0.1509 0.1925 0.2435 0.3083 0.3925 0.4975 10.0 inp
);
;

compile_audio_fn (
  let dust = fn density ->  
    let thresh = density * spf ;   # density (events/sec) * (1/sample_rate) = prob per sample
    let z = Math.rand_double ()  ;            # uniform [0, 1)
    match (z < thresh) with
    | true -> 1.
    | _ -> 0.
);

let int32_parse = extern fn String -> Int;
let parse_note = fn s ->
  let n = match (s[0]) with
  | 'c' -> 0
  | 'd' -> 2
  | 'e' -> 4
  | 'f' -> 5
  | 'g' -> 7
  | 'a' -> 9
  | 'b' -> 11
  | _ -> -1
  ;

  let (acc, oct) = match s[1] with
  | '#' -> (1, int32_parse (s[2 ..]))
  | '_' -> (-1, int32_parse (s[2 ..]))
  | _ -> (0, int32_parse (s[1 ..]))
  ;

  match n with
  | -1 -> None
  | _ -> Some @@ ((oct + 1) * 12) + n + acc
;;

let midi_freq = fn n ->
  440. * (Math.pow 2. ((n - 69.)/12.))
;;
