#     |> dsp_array.mapi (fn i d -> 
#       let (dl, dt) = dls[i];
#       dl[w] := inp + (
#         d
#         |> (*) (Math.pow 10.0 ((-3.0 * dt) / rt60)) # per-delay-line gamma output gain
#         |> Filter.lpf1p 8000
#         |> Filter.hpf1p 200
#       )
#     )
#     ;
#
#     counter[0]    := (w + 1) % max_size;
#     # inp + 0.25 * (y[0] + y[1] + y[2] + y[3])
#     inp + 0.25 * (y |> dsp_array.sum)
# );
compile_audio_fn ( 
  let fdn4 = fn d1 d2 d3 d4 rt60 inp -> 
    let M = [|
      -0.5,  0.5,  0.5,  0.5,
       0.5, -0.5,  0.5,  0.5,
       0.5,  0.5, -0.5,  0.5,
       0.5,  0.5,  0.5, -0.5
    |];
    let b = array_fill_const 4 1.;
    let c = array_fill_const 4 0.25;


    let dls = [|
      (delay_line 1, d1),
      (delay_line 1, d2),
      (delay_line 1, d3),
      (delay_line 1, d4),
    |];

    let dl0, _ = dls[0];
    let max_size = array_size dl0;

    let counter = [| 0 |];
    let w = counter[0];

    let y = dsp_array.map (fn (dl, dt) -> 
      tabread_samp dl (w - sample_rate * dt)
    ) dls;


    array_fill_const 4 0.
    |> dsp_mmul_op M y
    |> dsp_array.mapi (fn i d -> 
      let (dl, dt) = dls[i];
      dl[w] := inp * b[i] + (
        d
        |> (*) (Math.pow 10.0 ((-3.0 * dt) / rt60)) # per-delay-line gamma output gain
        |> Filter.lpf1p 8000
        |> Filter.hpf1p 200
      )
    )
    ;

    counter[0] := (w + 1) % max_size;
    inp + (vec_dot c y)
);

