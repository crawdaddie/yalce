open DSP;
let whisper = load_soundfile "whisper.wav";
# let whisper = load_soundfile "fat_amen_mono_48000.wav";

compile_audio_fn (
  let x = fn () ->

    trig 50
    |> grains
    100
    (array_of_buf whisper)
    1.
    (sin_osc 0.003
      |> scale_bp 0 1
      |> (+) (lfnoise 50 0 0.003)
    )
    0.07
    |> delay 0.2 0.2 0.4
  ;
);
#
x () |> play_node
