let buf = load_soundfile "./engine/assets/kick.wav";


import std/Math;

let f = compile_audio_fn (fn () -> 
  let t = trig 0;
  let s = t |> bufplay (bufref buf) (44100 / 48000) 0. |> (*) (adsr 0 0.1 0.9 0.44 t);
  s + Math.sin (7. * s)
);

f.cons [| |] |> play_node;

