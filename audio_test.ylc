let buf = load_soundfile "./engine/assets/kick.wav";


import std/Math;

let f = compile_audio_fn (fn rate -> 
  let t = trig 4;
  let s = t |> bufplay (bufref buf) (rate * 44100 / 48000) 0. |> (*) (adsr 0 0.5 1. 0.1 t);
  s + Math.sin (7. * s)
);

let x = f.cons [| 1.,|] |> play_node;


let ro = fn () ->
  x |> f.set_scalar "rate" 2. (get_tl_tick ());
  yield 0.25;
  x |> f.set_scalar "rate" 8. (get_tl_tick ());
  yield 0.25;
  x |> f.set_scalar "rate" 1. (get_tl_tick ());
  yield 0.25;
  x |> f.set_scalar "rate" 4. (get_tl_tick ());
  yield 0.25;
  yield ro () 
;;
#

defer_quant 1 (fn t ->
  ro () |> play_routine t schedule_event
)
