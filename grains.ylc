open engine/bindings/Synth; 
open engine/bindings/Sched; 
let amen = load_soundfile "whisper.wav";

let rates = [|
  1.,
  2.,
  # 0.5,
  1.5,
  # 4.
  # -1.,
  # -0.5,
|]
|> array_to_buf;

let synth = (fn () ->
  let trig = (impulse_node 30.) in
  grain_osc_node
  50
  (buf_ref amen)
  trig
  (ramp_node 0.005 |> (+) ((0.5 + 0.5 * sin_node 0.1) * (0.01 * trig_rand_node trig)))
  (trig_sel_node trig (buf_ref rates))
  # 1.
  0.2
) |> play_tpl



