open DSP;
open engine/bindings/Synth; 
open engine/bindings/Sched; 


let q = 1.;


play_pattern 1. (
  pat1: (
    [| 0.1, 1., 1., 1. |]
    |> iter_of_array
    |> cor_loop
    |> cor_map (fn d -> print `yield d: {d}\n`; d)
  )
);


