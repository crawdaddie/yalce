# let rfx = FDN.filter_delay.cons [| 0., 400., 0.25, 0.5, 0.9 |] |> play_node;
# let rfx = FDN.jot.cons [| 0., 7., 11000., 45. |] |> play_node;
# let rfx = FDN.tanh_delay.cons [| 0., 2., 0.25, 0.5, 0.8 |] |> play_node;
# let rfx = FDN.wobbly_fdn.cons [| 0. |] |> play_node;


# let rfx = FDN.jot.cons [| 0., 2.8, 5000., 120. |] |> play_node;
let rfx = FDN.fdn16.cons [| 0. |] |> play_node;

let q = 60. / 60.;

let pitches = [|100., 300., 600., 1200., 1200., 1300., 800.|];
let times = [| 0.5, 0.25, 0.25, 0.5, 1. |];

defer_quant 0.1 (fn t -> 
  (dur: (fn () -> Math.array_choose times), freq: (fn () -> Math.array_choose pitches))

  |> cor_zip_struct
  |> cor_map (fn (d, freq) -> 

    f.cons [| freq, |] |> play_into rfx;
    d * q
  ) 
  |> play_routine t schedule_event
);


