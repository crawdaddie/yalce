open DSP;
open engine/bindings/Sched; 

import std/Math;
let f = compile_audio_fn (fn freq -> 
  sin_osc freq
  |> (*) (adsr 0.03 0.1 1. 0.15 (trig 0) |> kill_on_end)
  |> (*) 0.5
);

# let FDN = module () -> 
#   let _ = register_audio_op (
#     let fdn = (fn d1 max_delay inp -> 
#       let max_buf_size = max_delay * spf ();
#       let dbuf1 = array_fill_const max_buf_size 0.;
#       let dbuf2 = array_fill_const max_buf_size 0.;
#       let dbuf3 = array_fill_const max_buf_size 0.;
#       let dbuf4 = array_fill_const max_buf_size 0.;
#
