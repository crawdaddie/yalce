#%%
# 14.3 secs

play_pattern (16 * q, -4. * q) (
  let pm_pattern = empty_cor ();
  let clps = empty_cor ();

  let vloop = fn () ->
    Vocals.trig 14.3;
    yield 64.;
    yield vloop ()
  ;;

  let vp = (let x = 
    (fn () ->
      Vocals.silence ();
      yield 4.;
      yield vloop ()
    )
    in x () |> cor_map (fn d-> d * q)
  );

  let hh_pat = fn () ->
    yield 2.;
    click () |> play_node;
    yield 4.;
    click () |> play_node;
    yield 2.;
    yield hh_pat ()
  ;;

  let hihats = (let x = (fn () ->
    yield 4.;
    yield hh_pat ()
  ) in x () |> cor_map (fn d -> d * q));

  let kk = fn () ->
    airy_kick (33. |> midi_to_freq) 1. |> play_node;
    yield 3.;
    airy_kick (33. |> midi_to_freq) 1. |> play_node;
    yield 2.;
    airy_kick (33. |> midi_to_freq) 1. |> play_node;
    yield 3.;
    yield kk ()
  ;;

  let kick_pat = (let x = (fn () ->
    impact () |> play_node;
    yield 1.;
    impact () |> play_node;
    yield 1.;
    impact () |> play_node;
    yield 2.;
    # yield kk 0
    yield kk ()
    ) in x () |> cor_map (fn d -> d * q))
);

#%%
play_pattern (8. * q, -1. * q) (

  let kk = fn () ->

    impact () |> play_node;
    yield 3.;

    impact () |> play_node;
    yield 2.;

    impact () |> play_node;
    yield 3.;


    impact () |> play_node;
    yield 3.;

    impact () |> play_node;
    yield 2.;

    impact () |> play_node;
    yield 2.;

    impact () |> play_node;
    yield 1.;
    yield kk ()
  ;;

  let kick_pat = (let x = (fn () ->
    impact () |> play_node;
    yield 1.;
    yield kk ()
    ) in x () |> cor_map (fn d -> d * q))
);





#%%

let harm_synth = @Audio fn f dur ->
  let t = trig 0;

  saw_osc (f * ~[1., 1.5]) 
  |> mix 1
  |> Filter.lpf (t |> decay 1. |> scale (2. * f) (6. * f) ) 5. 
  |> (*) (t |> rect dur |> adsr 0. 0.1 0.5 0.01 |> kill_on_end)
;;

play_pattern (16 * q) (
  let kick_pat = empty_cor ();

  let vp = (let x = 
    (fn () ->
      Vocals.trig 39.7;
      yield 64.
    )
    in x () |> cor_loop |> cor_map (fn d-> d * q)
  );

  let chorus_riff = (
    dur: pat `6 6 4`,
    n: pat `33 40 `
  )
  |> cor_zip_struct
  |> cor_map (fn (d, n) ->
    # print `note: {Double n}\n`;
    harm_synth (midi_to_freq (Double n)) (d * q * 0.5) |> play_node;
    d * q * .5
  )
);
