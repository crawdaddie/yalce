let transient_positions = fn a ->
  let val0 = a[0];
  let l = [| [0., ] |];
  let s = [| 0 |];

  for i = 0 .. array_size a in (
    if (a[i] > 0.) then (
      # print `non-zero trans {i}: {a[i]} / {array_size a} {(Double i) / array_size a}\n`;
      l[0] := ((Double i) / (array_size a))::(l[0]);
      s[0] := 1 + s[0]
    )
  );


  let res = array_fill_const (s[0]) 0.;

  let list_to_arr = fn l res i ->
    match i with 
    | 0 -> (
      let x::rest = l;

      # print `setting {x} to {i}\n`;
      res[i] := x;
      res
    )
    | _ -> (
      let x::rest = l;
      res[i] := x;
      # print `setting {x} to {i}\n`;
      list_to_arr rest res (i - 1)
    )
  ;;
  list_to_arr (l[0]) res (s[0] - 1);
  res
;;


