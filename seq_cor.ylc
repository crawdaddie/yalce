import Patterns;

type CorSeq = 
| CorInt of Int
| CorNum of Double
| CorKey of String
| CorList of Array of CorSeq
| CorChoose of Array of CorSeq
| CorAlt of Coroutine of CorSeq
;

print @@ typeof CorSeq;
print "\n\n";

